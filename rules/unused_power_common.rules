import org.eclipse.smarthome.model.script.ScriptServiceUtil

rule "Default boot values"
when
	System started
then
	AvailablePower.sendCommand(0)
	AvailablePowerProcessStatus.sendCommand("finished")

	//testing stuff, to be removed

	DestinationDevices.sendCommand("Calentador,Cotxe")
	Calentador_UsedPower.sendCommand(500)
	Cotxe_UsedPower.sendCommand(2300)
end

rule "Manage unused power"
when
    Time cron "0/30 * 7-21 ? * * *"
    or System started
then
    val engineStatus = AvailablePowerProcessStatus.state
	if(engineStatus == "finished"){
	    val unusedPower = (SunnyBoy_Pot_Rebutjada.state as Number).intValue
		val devices = DestinationDevices.state.toString.split(',')
		var availablePower = unusedPower
		var i = 0
		while(i<devices.length){
			val currentItem = ScriptServiceUtil.getItemRegistry.getItem(devices.get(i) + "_UsedPower")
			availablePower = availablePower + currentItem.state
		}
		logWarn("UnusedPower","Currently unused power is "+unusedPower+", available power is "+availablePower)

		//TODO update all devices available power in order
    }else{
    	//TODO record that it has been finished and send a notification if not executed after N tries

    }

end